## Project storage (PROJECT_ROOT). Track only the directory skeleton.
dataspaces/**
!dataspaces/data_lake/
!dataspaces/data_warehouse/
!dataspaces/retrieved_data/
!dataspaces/**/.gitkeep

## Python build / test artifacts
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.venv/
venv/

## MkDocs site
site/
_site_check/

## DuckDB files
*.db
*.ddb

## Dagster ephemeral home dirs (created by execute_in_process / dagster dev)
.tmp_dagster_home_*/
dagster_home/

## Docker image tarballs
build/**/*.tar
docker/*

## Environment files — keep .env.example tracked as the template, but
## NEVER commit machine-specific .env / .env.* files (they contain
## credentials and host paths that must not leave the developer's box).
.env
.env.*
!.env.example

## Local helper scripts
start-duckdb.sh
