## Copy this file to `.env` and adjust for your environment:
##   cp .env.example .env

ENVIRONMENT=development

## ----------------------------------------------------------------------
## DuckDB / S3 client settings
## ----------------------------------------------------------------------
S3_ENDPOINT=http://minio:9090
S3_USE_SSL=false
S3_REGION=us-east-1

## REQUIRED — set your own values. These are the credentials the DatorCloud
## components (MinIO client + DuckDB httpfs) use to authenticate against the
## object store. Leave the placeholders untouched and the framework will
## refuse to start with a clear `ValueError` from MinioObjectComponent /
## QueryComponent.
##   - S3_ACCESS_KEY -> 3+ characters
##   - S3_SECRET_KEY -> 8+ characters
S3_ACCESS_KEY=
S3_SECRET_KEY=

## ----------------------------------------------------------------------
## MinIO Service
## ----------------------------------------------------------------------
## REQUIRED — set your own values, and keep them in sync with the
## S3_ACCESS_KEY / S3_SECRET_KEY pair above (the docker-compose stack uses
## the MINIO_ROOT_* pair to *create* the user, then DatorCloud connects
## with the S3_* pair). MinIO enforces:
##   - MINIO_ROOT_USER     -> 3+ characters
##   - MINIO_ROOT_PASSWORD -> 8+ characters
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=9090
MINIO_CONSOLE_PORT=9091

## ----------------------------------------------------------------------
## Storage architecture
## ----------------------------------------------------------------------
## All project storage lives under PROJECT_ROOT. Override this to point at a
## different host directory (absolute path, or path relative to docker-compose.yml).
PROJECT_ROOT=./dataspaces

DATA_LAKE_PATH=${PROJECT_ROOT}/data_lake               # raw datasets (mounted into Python containers)
DATA_WAREHOUSE_PATH=${PROJECT_ROOT}/data_warehouse     # MinIO bucket-backing storage
RETRIEVED_DATA_PATH=${PROJECT_ROOT}/retrieved_data     # download target for `retrieve`
