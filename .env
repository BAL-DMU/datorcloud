ENVIRONMENT=development

## DuckDB Service
DUCKDB_PORT=8001
S3_ENDPOINT=http://minio:9000
S3_USE_SSL=false
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin


## MinIO Service
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
DATAWAREHOUSE_PATH=/data/02_OR-X/datasets/orx-datalake
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001


## Python Runner Service
DATALAKE_PATH=/app/data 
RETRIEVED_DATA_PATH=/app/retrieved_data